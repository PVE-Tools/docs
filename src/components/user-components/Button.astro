---
const { label, link, variant = "primary", size = "default", class: className = "" } = Astro.props;

const base = "inline-flex items-center justify-center whitespace-nowrap rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 disabled:pointer-events-none disabled:opacity-50";

const variants = {
  primary: "bg-primary text-white hover:brightness-110",
  secondary: "border border-primary text-primary hover:bg-primary hover:text-white",
  ghost: "text-primary hover:bg-primary/10",
};

const sizes = {
  default: "h-10 px-4 py-2",
  sm: "h-9 rounded-md px-3",
  lg: "h-11 rounded-md px-8",
};

const classes = `${base} ${variants[variant] || variants.primary} ${sizes[size] || sizes.default} ${className}`.trim();
---
<a href={link} class={classes}>{label}</a>